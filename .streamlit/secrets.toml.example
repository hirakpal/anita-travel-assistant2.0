# ANITA Travel Assistant - Streamlit Secrets Configuration
# Copy this file to .streamlit/secrets.toml and fill in your API keys

# Google APIs
GOOGLE_API_KEY = "your_google_api_key_here"
GOOGLE_MAPS_API_KEY = "your_google_maps_api_key_here"

# Pinecone Vector Database
PINECONE_API_KEY = "your_pinecone_api_key_here"
PINECONE_HOST = "https://your-pinecone-host.svc.aped-4627-b74a.pinecone.io"

# Aviation APIs
AVIATIONSTACK_API_KEY = "your_aviationstack_api_key_here"

# Application Configuration
[app]
mode = "demo"  # "demo" or "online"
debug = false
log_level = "INFO"

# Feature Flags
[features]
enable_flights = true
enable_hotels = true
enable_transport = true
enable_activities = true
enable_dining = true
enable_weather_alerts = true
enable_impact_analysis = true
